{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
        "webserver": {
            "projectType": "library",
            "root": "projects/webserver",
            "sourceRoot": "projects/webserver/src",
            "prefix": "lib",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-ng-packagr:build",
                    "options": {
                        "tsConfig": "projects/webserver/tsconfig.lib.json",
                        "project": "projects/webserver/ng-package.json"
                    },
                    "configurations": {
                        "production": {
                            "tsConfig": "projects/webserver/tsconfig.lib.prod.json"
                        }
                    }
                },
                "lint": {
                    "builder": "@angular-devkit/build-angular:tslint",
                    "options": {
                        "tsConfig": [
                            "projects/webserver/tsconfig.lib.json"
                        ],
                        "exclude": [
                            "**/node_modules/**"
                        ]
                    }
                }
            }
        }
    },
    "defaultProject": "webserver"
}
